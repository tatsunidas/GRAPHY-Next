---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="ページが見つかりません" path="/404">
  <section class="section">
    <div class="container" style="max-width:640px;text-align:center">
      <h1 style="font-size:clamp(2.5rem,10vw,4rem)" class="grad-text">404</h1>
      <p class="lead" style="margin-inline:auto">
        お探しのページは見つかりませんでした。
      </p>
      <a class="button button--primary" href="/">ホームへ戻る</a>
    </div>
  </section>
</BaseLayout>
