---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { classicFeatures, disclaimerShort } from '../../data/site';
---

<BaseLayout
  title="GRAPHY classic"
  description="GRAPHY classic は Java Swing の DICOM ビューア／ワークステーション。GRAPHY-Next の前身。無料・MPL-2.0・寄付で運営。"
  path="/classic"
>
  <section class="section section--tight">
    <div class="container">
      <span class="eyebrow">GRAPHY classic</span>
      <h1>実績ある Java Swing 版 DICOM ワークステーション</h1>
      <p class="lead">
        GRAPHY-Next の前身。2D / 3D ビューア、MPR、ROI 解析、プラグイン機構を備えたデスクトップアプリ。
        無料で、寄付により運営を支えられます。
      </p>
      <div class="hero__cta">
        <a class="button button--primary" href="/classic/download">▼ 無料ダウンロード</a>
        <a class="button button--ghost" href="/classic/donate">♥ 寄付する</a>
      </div>
      <p class="badge badge--accent" style="margin-top:1rem">{disclaimerShort}</p>
    </div>
  </section>

  <section class="section" style="background:var(--surface)">
    <div class="container">
      <h2>主な機能</h2>
      <div class="grid grid--3" style="margin-top:1.5rem">
        {classicFeatures.map((f) => (
          <div class="card">
            <div class="card__icon">{f.icon}</div>
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </div>
        ))}
      </div>
      <p style="margin-top:1.5rem">
        使い方は <a href="https://tatsunidas.github.io/GRAPHY/" rel="noopener" target="_blank">ユーザーマニュアル（GitHub Pages）</a> を参照してください。
      </p>
    </div>
  </section>

  <style>
    .hero__cta { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1rem; }
  </style>
</BaseLayout>
