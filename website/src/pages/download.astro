---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="ダウンロード" path="/download">
  <section class="section">
    <div class="container" style="max-width:820px">
      <span class="eyebrow">Download</span>
      <h1>ダウンロード</h1>
      <p class="lead">お使いになる製品を選んでください。どちらも無料です。</p>

      <div class="grid grid--2" style="margin-top:1.5rem">
        <a class="card card--hover" href="/next/download">
          <div class="card__icon">◈</div>
          <h3>GRAPHY-Next</h3>
          <p>次世代版。スタンドアロン（オフライン）＋ Web（PACS 連携）。AGPL-3.0。</p>
          <span style="color:var(--accent);font-weight:700;display:inline-block;margin-top:0.75rem">ダウンロードへ →</span>
        </a>
        <a class="card card--hover" href="/classic/download">
          <div class="card__icon">◇</div>
          <h3>GRAPHY classic</h3>
          <p>実績ある Java Swing 版（前身）。MPL-2.0。寄付で運営を支えられます。</p>
          <span style="color:var(--accent);font-weight:700;display:inline-block;margin-top:0.75rem">ダウンロードへ →</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
