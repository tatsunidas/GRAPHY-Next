---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { lab } from '../../data/site';
const plugins = lab.plugins.filter((p) => p.published);
---

<BaseLayout
  title="GRAPHY Lab"
  description="GRAPHY の使い方とプラグイン。How-to、プラグイン開発ガイド、プラグイン紹介。"
  path="/lab"
>
  <section class="section section--tight">
    <div class="container">
      <span class="eyebrow">GRAPHY Lab</span>
      <h1>使い方と、プラグイン</h1>
      <p class="lead">{lab.intro}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid--2">
        {lab.sections.map((s) => (
          <a class="card card--hover" href={s.href} rel="noopener" target="_blank">
            <h3>{s.title} ↗</h3>
            <p>{s.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--surface)">
    <div class="container">
      <span class="eyebrow">Plugins</span>
      <h2>プラグイン紹介</h2>
      {plugins.length > 0 ? (
        <div class="grid grid--3" style="margin-top:1.5rem">
          {plugins.map((p) => (
            <div class="card">
              <h3>{p.name}</h3>
              <p>{p.tagline}</p>
              {p.repo && <a href={p.repo} rel="noopener" target="_blank">リポジトリ ↗</a>}
            </div>
          ))}
        </div>
      ) : (
        <p class="lead" style="margin-top:1rem">
          プラグインの紹介は準備中です。プラグイン機構を使えば、独自の解析・処理を GRAPHY に追加できます。
          開発ガイドは上記のリンクをご覧ください。
        </p>
      )}
    </div>
  </section>
</BaseLayout>
