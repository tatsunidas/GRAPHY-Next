---
import BaseLayout from '../layouts/BaseLayout.astro';
import EmailCapture from '../components/EmailCapture.astro';
import { home, nextFeatures, site, disclaimerShort } from '../data/site';
---

<BaseLayout path="/">
  <!-- HERO -->
  <section class="hero">
    <div class="container hero__inner">
      <span class="badge badge--accent">{disclaimerShort}</span>
      <h1 class="hero__title">{home.heroTitle}</h1>
      <p class="lead hero__lead">{home.heroSub}</p>
      <div class="hero__cta">
        <a class="button button--primary" href="/download">▼ 無料ダウンロード</a>
        <a class="button button--ghost" href="/demo" aria-disabled="true">● 実働デモ（近日公開）</a>
      </div>
      <p class="hero__os">Windows ・ macOS ・ Linux ／ オープンソース（AGPL-3.0）</p>
    </div>
  </section>

  <!-- PRODUCTS -->
  <section class="section">
    <div class="container">
      <span class="eyebrow">Products</span>
      <h2>GRAPHY ファミリー</h2>
      <div class="grid grid--3" style="margin-top:1.5rem">
        {home.products.map((p) => (
          <a class="card card--hover product-card" href={p.href}>
            <div class="card__icon">{p.symbol}</div>
            <h3>{p.name}</h3>
            <p>{p.desc}</p>
            <span class="product-card__more">詳しく見る →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="section" style="background:var(--surface)">
    <div class="container">
      <span class="eyebrow">Capabilities</span>
      <h2>研究に必要な機能を、一気通貫で</h2>
      <p class="lead">画像の読み込みから 3D・定量解析まで。GRAPHY-Next の主な機能。</p>
      <div class="grid grid--3" style="margin-top:1.75rem">
        {nextFeatures.map((f) => (
          <div class="card">
            <div class="card__icon">{f.icon}</div>
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY FREE -->
  <section class="section">
    <div class="container why">
      <div>
        <span class="eyebrow">Open source</span>
        <h2>なぜ無料なのか</h2>
        <p class="lead">
          GRAPHY-Next はオープンソース（AGPL-3.0）です。研究・教育での利用は無償。
          有償の技術サポート購読や、将来のクラウド／エンタープライズ機能で開発を支えます。
        </p>
        <p>
          <a href="/legal/licenses">ライセンスについて</a> ・
          <a href={site.githubOrgUrl} rel="noopener" target="_blank">GitHub</a>
        </p>
      </div>
      <div class="why__cta card">
        <h3>はじめる</h3>
        <p>インストーラを入手して、すぐに使えます。</p>
        <a class="button button--primary" href="/download">ダウンロードへ</a>
        <EmailCapture source="home" />
      </div>
    </div>
  </section>

  <style>
    .hero {
      position: relative; overflow: hidden;
      background:
        radial-gradient(1000px 500px at 15% -10%, color-mix(in srgb, var(--accent) 18%, transparent), transparent 60%),
        radial-gradient(900px 500px at 100% 0%, color-mix(in srgb, var(--accent-2) 20%, transparent), transparent 55%);
      border-bottom: 1px solid var(--border);
    }
    .hero__inner { padding-block: clamp(3.5rem, 10vw, 6.5rem); display: grid; gap: 1.1rem; max-width: 820px; }
    .hero__title { font-size: clamp(2rem, 6vw, 3.5rem); letter-spacing: -0.01em; }
    .hero__lead { margin: 0; }
    .hero__cta { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 0.5rem; }
    .hero__os { color: var(--muted); font-size: 0.88rem; margin: 0; }
    .product-card { display: flex; flex-direction: column; gap: 0.35rem; color: var(--fg); }
    .product-card__more { margin-top: auto; color: var(--accent); font-weight: 700; font-size: 0.9rem; padding-top: 0.75rem; }
    .why { display: grid; grid-template-columns: 1.4fr 1fr; gap: 2rem; align-items: center; }
    .why__cta { display: flex; flex-direction: column; gap: 0.6rem; align-items: flex-start; }
    @media (max-width: 860px) { .why { grid-template-columns: 1fr; } }
  </style>
</BaseLayout>
