---
import { footer, site, disclaimerShort } from '../data/site';
const year = new Date().getFullYear();
const isExternal = (href: string) => href.startsWith('http') || href.startsWith('mailto:');
---

<footer class="site-footer">
  <hr class="spectrum-rule" />
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      <a class="brand" href="/"><span class="brand__mark" aria-hidden="true">◈</span> {site.brand}</a>
      <p class="site-footer__tag">{site.tagline}</p>
      <p class="badge badge--accent">{disclaimerShort}</p>
    </div>

    <nav class="site-footer__cols" aria-label="フッター">
      {footer.columns.map((col) => (
        <div class="site-footer__col">
          <h4>{col.heading}</h4>
          <ul>
            {col.links.map((l) => (
              <li>
                <a
                  href={l.href}
                  {...(isExternal(l.href) ? { rel: 'noopener', target: '_blank' } : {})}
                >{l.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </nav>
  </div>

  <div class="container site-footer__bottom">
    <span>© {year} {site.company}</span>
    <span>Powered by <a href={site.companyUrl} rel="noopener" target="_blank">Visionary Imaging Services</a></span>
  </div>
</footer>

<style>
  .site-footer { margin-top: 4rem; background: var(--surface); border-top: 1px solid var(--border); }
  .spectrum-rule { margin: 0; }
  .site-footer__inner { display: grid; grid-template-columns: 1.2fr 2fr; gap: 2rem; padding-block: 2.5rem 1.5rem; }
  .site-footer__tag { color: var(--muted); font-size: 0.92rem; max-width: 32ch; }
  .site-footer__cols { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem; }
  .site-footer__col h4 { font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted); margin-bottom: 0.6rem; }
  .site-footer__col ul { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.4rem; }
  .site-footer__col a { color: var(--fg); font-size: 0.9rem; }
  .site-footer__col a:hover { color: var(--accent); }
  .site-footer__bottom {
    display: flex; flex-wrap: wrap; gap: 0.5rem 1rem; justify-content: space-between;
    padding-block: 1.25rem; border-top: 1px solid var(--border); color: var(--muted); font-size: 0.85rem;
  }
  .brand { display: inline-flex; align-items: center; gap: 0.4rem; color: var(--fg); font-weight: 800; }
  .brand__mark { background: var(--grad-accent); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; }
  @media (max-width: 860px) {
    .site-footer__inner { grid-template-columns: 1fr; }
    .site-footer__cols { grid-template-columns: repeat(2, 1fr); }
  }
</style>
