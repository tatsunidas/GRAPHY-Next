---
export interface Props {
  source: string;
}
const { source } = Astro.props;
---

<form class="email-capture" action="/api/subscribe.php" method="post" data-source={source}>
  <label class="email-capture__label" for={`email-${source}`}>
    更新通知を受け取る（任意）
  </label>
  <div class="email-capture__row">
    <input
      id={`email-${source}`}
      type="email"
      name="email"
      inputmode="email"
      autocomplete="email"
      placeholder="you@example.com"
      required
    />
    <button type="submit" class="button button--ghost">登録</button>
  </div>
  <input type="hidden" name="source" value={source} />
  <!-- honeypot: bots fill this; humans never see it -->
  <input type="text" name="website" class="email-capture__hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
  <p class="email-capture__note" data-role="msg">
    新バージョンの公開時にお知らせします。いつでも解除できます。
  </p>
</form>

<script is:inline>
  (function () {
    document.querySelectorAll('.email-capture').forEach(function (form) {
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var msg = form.querySelector('[data-role="msg"]');
        if (form.querySelector('.email-capture__hp').value) return; // honeypot tripped
        var data = new FormData(form);
        fetch(form.action, { method: 'POST', body: data })
          .then(function (r) { return r.ok ? r : Promise.reject(r); })
          .then(function () {
            if (msg) { msg.textContent = '登録しました。ありがとうございます。'; }
            form.reset();
            if (window.track) window.track('email_submit', { source: form.dataset.source });
          })
          .catch(function () {
            if (msg) { msg.textContent = '送信に失敗しました。時間をおいて再度お試しください。'; }
          });
      });
    });
  })();
</script>

<style>
  .email-capture { margin-top: 1rem; max-width: 460px; }
  .email-capture__label { display: block; font-size: 0.9rem; font-weight: 600; margin-bottom: 0.4rem; }
  .email-capture__row { display: flex; gap: 0.5rem; }
  .email-capture input[type="email"] {
    flex: 1; padding: 0.6rem 0.8rem; border: 1px solid var(--border); border-radius: var(--radius-sm);
    background: var(--surface); color: var(--fg); font: inherit;
  }
  .email-capture__hp { position: absolute; left: -9999px; width: 1px; height: 1px; opacity: 0; }
  .email-capture__note { font-size: 0.82rem; color: var(--muted); margin: 0.5rem 0 0; }
</style>
