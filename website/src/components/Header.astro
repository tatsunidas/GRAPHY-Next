---
import { site } from '../data/site';
const path = Astro.url.pathname;
const isActive = (href: string) => path === href || (href !== '/' && path.startsWith(href));
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="brand" href="/" aria-label={`${site.brand} ホーム`}>
      <img class="brand__mark" src="/graphy-icon.png" alt="" width="28" height="28" />
      <span class="brand__name">{site.brand}</span>
    </a>

    <button class="nav-toggle" aria-expanded="false" aria-controls="site-nav" aria-label="メニュー">
      <span></span><span></span><span></span>
    </button>

    <nav id="site-nav" class="site-nav" aria-label="メイン">
      <ul class="site-nav__list">
        {site.nav.map((item) => (
          <li>
            {item.comingSoon ? (
              <a href={item.href} class="site-nav__link" aria-disabled="true">
                {item.label}<span class="soon">近日</span>
              </a>
            ) : (
              <a href={item.href} class={`site-nav__link${isActive(item.href) ? ' is-active' : ''}`}>
                {item.label}
              </a>
            )}
          </li>
        ))}
      </ul>

      <div class="site-header__actions">
        <div class="lang-switch" role="group" aria-label="言語">
          <span class="lang-switch__item is-active" aria-current="true">JA</span>
          <span class="lang-switch__item is-disabled" title="準備中">EN</span>
        </div>
        <button id="theme-toggle" class="icon-button" aria-label="テーマ切り替え" title="ライト/ダーク">◐</button>
        <a class="button button--ghost" href={site.sponsorsUrl} rel="noopener" target="_blank">♥ Support</a>
      </div>
    </nav>
  </div>
</header>

<script is:inline>
  (function () {
    var toggle = document.querySelector('.nav-toggle');
    var nav = document.getElementById('site-nav');
    if (toggle && nav) {
      toggle.addEventListener('click', function () {
        var open = nav.classList.toggle('is-open');
        toggle.setAttribute('aria-expanded', String(open));
      });
    }
    var theme = document.getElementById('theme-toggle');
    if (theme) {
      theme.addEventListener('click', function () {
        var cur = document.documentElement.getAttribute('data-theme') === 'light' ? 'light' : 'dark';
        var next = cur === 'light' ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', next);
        try { localStorage.setItem('graphy-theme', next); } catch (e) {}
      });
    }
  })();
</script>

<style>
  .site-header {
    position: sticky; top: 0; z-index: 800;
    backdrop-filter: saturate(140%) blur(10px);
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    border-bottom: 1px solid var(--border);
  }
  .site-header__inner { display: flex; align-items: center; justify-content: space-between; height: var(--header-h); gap: 1rem; }
  .brand { display: inline-flex; align-items: center; gap: 0.5rem; color: var(--fg); font-weight: 800; font-size: 1.15rem; letter-spacing: 0.02em; }
  .brand__mark { width: 28px; height: 28px; background: #fff; border-radius: 7px; padding: 2px; display: block; }
  .site-nav { display: flex; align-items: center; gap: 1.5rem; }
  .site-nav__list { display: flex; align-items: center; gap: 0.3rem; list-style: none; margin: 0; padding: 0; }
  .site-nav__link { color: var(--fg); font-size: 0.94rem; font-weight: 600; padding: 0.45rem 0.7rem; border-radius: var(--radius-sm); display: inline-flex; align-items: center; gap: 0.35rem; }
  .site-nav__link:hover { background: var(--surface-2); color: var(--accent); opacity: 1; }
  .site-nav__link.is-active { color: var(--accent); background: var(--surface-2); }
  .site-nav__link[aria-disabled="true"] { color: var(--muted); cursor: default; }
  .soon { font-size: 0.62rem; font-weight: 700; color: var(--accent-2); border: 1px solid var(--border); border-radius: 999px; padding: 0.05rem 0.35rem; }
  .site-header__actions { display: flex; align-items: center; gap: 0.6rem; }
  .lang-switch { display: inline-flex; border: 1px solid var(--border); border-radius: 999px; overflow: hidden; font-size: 0.78rem; font-weight: 700; }
  .lang-switch__item { padding: 0.25rem 0.55rem; color: var(--muted); }
  .lang-switch__item.is-active { background: var(--surface-2); color: var(--accent); }
  .lang-switch__item.is-disabled { opacity: 0.5; }
  .icon-button { background: transparent; border: 1px solid var(--border); color: var(--fg); border-radius: 999px; width: 2.1rem; height: 2.1rem; cursor: pointer; font-size: 1rem; }
  .icon-button:hover { border-color: var(--accent); color: var(--accent); }
  .nav-toggle { display: none; flex-direction: column; gap: 4px; background: transparent; border: 0; cursor: pointer; padding: 0.4rem; }
  .nav-toggle span { width: 22px; height: 2px; background: var(--fg); border-radius: 2px; }

  @media (max-width: 860px) {
    .nav-toggle { display: flex; }
    .site-nav {
      position: absolute; top: var(--header-h); inset-inline: 0;
      flex-direction: column; align-items: stretch; gap: 0.5rem;
      background: var(--bg); border-bottom: 1px solid var(--border);
      padding: 1rem 1.25rem; box-shadow: var(--shadow);
      transform: translateY(-8px); opacity: 0; pointer-events: none; transition: opacity 0.15s ease, transform 0.15s ease;
    }
    .site-nav.is-open { transform: translateY(0); opacity: 1; pointer-events: auto; }
    .site-nav__list { flex-direction: column; align-items: stretch; }
    .site-header__actions { justify-content: space-between; }
  }
</style>
