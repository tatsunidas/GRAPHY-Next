{
  "name": "graphy-next-desktop",
  "version": "0.1.7",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "description": "GRAPHY-Next desktop (Electron) — standalone mode",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^31.7.3",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.vis.graphynext",
    "productName": "GRAPHY-Next",
    "files": ["main.js", "preload.js", "windowState.js", "splash.html", "splash-preload.js", "config.json", "renderer/**"],
    "extraResources": [
      { "from": "resources/backend", "to": "backend" },
      { "from": "resources/jre", "to": "jre" },
      { "from": "resources/ffmpeg", "to": "ffmpeg" },
      { "from": "resources/dcm4che", "to": "dcm4che" },
      { "from": "uninstall", "to": "uninstall" }
    ],
    "linux": { "target": ["AppImage"] },
    "win": { "target": ["nsis"] },
    "mac": { "target": ["dmg"] },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "include": "build/installer.nsh"
    }
  }
}
