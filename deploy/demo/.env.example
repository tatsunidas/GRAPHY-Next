# deploy/demo/.env のテンプレート。これをコピーして .env を作り、実トークンを入れる:
#   cp deploy/demo/.env.example deploy/demo/.env
# .env は .gitignore 済み（トークンをコミットしないこと）。
#
# TUNNEL_TOKEN は Cloudflare Zero Trust → Networks → Tunnels で
# named tunnel を作成した際に表示される `eyJ...` で始まる文字列。
# cloudflared がこの環境変数を自動で読み、`tunnel run` で named tunnel に接続する。
TUNNEL_TOKEN=eyJ...replace-me...

# --- マジックリンクログインゲート（graphy-backend の AuthFilter + mailer サイドカー） ---

# セッションCookie署名用のHMAC共有鍵。生成例: openssl rand -base64 32
GRAPHY_AUTH_SESSION_SECRET=replace-me-with-openssl-rand--base64-32

# graphy-backend → mailer の内部API呼び出しを認証する共有鍵（両者で同じ値にする）。生成例: openssl rand -hex 32
GRAPHY_AUTH_INTERNAL_API_KEY=replace-me-with-openssl-rand--hex-32

# graphy.vis-ionary.com（Xserver, website/public/api/subscribe.php）からの POST /subscribe を
# 認証する共有鍵（Xserver側にも同じ値を配置すること）。生成例: openssl rand -hex 32
GRAPHY_AUTH_SUBSCRIBE_API_KEY=replace-me-with-openssl-rand--hex-32

# Cloudflare Turnstile のサイトキー（公開情報。ログイン画面に埋め込まれる）。
# https://dash.cloudflare.com/ → Turnstile でウィジェットを作成して取得する。
GRAPHY_AUTH_TURNSTILE_SITE_KEY=0x...replace-me...

# Turnstile のシークレットキー（非公開。mailer が siteverify 呼び出しに使う）。
TURNSTILE_SECRET_KEY=0x...replace-me...

# 既存のSMTPアカウントを流用してマジックリンクメールを送信する（mailer サイドカー）。
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace-me@example.com
SMTP_PASS=replace-me
SMTP_FROM="GRAPHY-Next Demo <replace-me@example.com>"
